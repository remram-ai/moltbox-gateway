# Together API key is required for cloud escalation.
# Leave blank in VCS; set locally in container.env.
TOGETHER_API_KEY=

# Stable local model runtime image tag.
OLLAMA_IMAGE=ollama/ollama:0.6.8

# Internal service endpoints (no host exposure for these services).
OLLAMA_BASE_URL=http://ollama:11434
OPENSEARCH_URL=http://opensearch:9200

# Local routing defaults.
LOCAL_ROUTING_MODEL=qwen3:8b
CLOUD_PROVIDER=together
CLOUD_REASONING_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8
DEEP_THINKING_MODEL=Qwen/Qwen3-235B-A22B-Thinking-2507
CODING_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8

# Runtime behavior controls.
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000

# Discord bot token for the owning runtime.
# Use one bot token per runtime environment.
DISCORD_BOT_TOKEN=

# OpenSearch runtime posture.
DISCOVERY_TYPE=single-node
PLUGINS_SECURITY_DISABLED=true
OPENSEARCH_JAVA_OPTS="-Xms2g -Xmx2g"
